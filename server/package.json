{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc -p tsconfig.json",
    "render:build": "npm install --include=dev && npm run build",
    "start": "node dist/index.js",
    "setup:mcp": "node scripts/setup-excalidraw-mcp.mjs",
    "postinstall": "node scripts/setup-excalidraw-mcp.mjs --warn-only",
    "eval": "ts-node src/eval/run.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.0",
    "axios": "^1.9.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "groq-sdk": "^0.37.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.24.0",
    "nanoid": "^3.3.12",
    "nodemailer": "^9.0.1",
    "typescript": "^5.8.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
