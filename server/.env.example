# ─── V2 ADDITIONS ───
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/ai-drawing-engine
# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_64_char_hex_string_here
JWT_REFRESH_SECRET=your_different_64_char_hex_string_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

GROQ_API_KEY=your_groq_key_here
# Optional: defaults to llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile
PEXELS_API_KEY=your_pexels_key_here
PORT=3001

# Optional: override path to built Excalidraw MCP stdio entry
# EXCALIDRAW_MCP_PATH=D:\path\to\excalidraw-mcp\dist\index.js
