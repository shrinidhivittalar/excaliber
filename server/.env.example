PORT=3001
GROQ_API_KEY=your_groq_api_key_here

# Required for real image fetching (fetch_images tool)
# Get free key at https://www.pexels.com/api — 200 requests/hour free
PEXELS_API_KEY=your_pexels_key_here
GROQ_MODEL=llama-3.3-70b-versatile
MONGODB_URI=mongodb://localhost:27017/excaliber
JWT_SECRET=your_jwt_secret_here
CLIENT_URL=http://localhost:5173
# Required in production - the exact origin your frontend is served from
ALLOWED_ORIGIN=https://your-production-domain.com

# Per-user rate limit (requests per window)
USER_RATE_LIMIT_COUNT=10
USER_RATE_LIMIT_MS=60000
INGEST_RATE_LIMIT_COUNT=5

# Daily token limit per user (100k ≈ 65 average diagram requests)
DAILY_TOKEN_LIMIT=100000

# Visual feedback loop (Phase 9)
# Critique uses Groq vision — same GROQ_API_KEY, no new key needed
CRITIQUE_RATE_LIMIT_COUNT=5
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct


 GMAIL_USER=your_gmail@gmail.com
 GMAIL_APP_PASSWORD=your_16_char_app_password
