PORT=3001
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
MONGODB_URI=mongodb://localhost:27017/excaliber
JWT_SECRET=your_jwt_secret_here
CLIENT_URL=http://localhost:5173

# Per-user rate limit (requests per window)
USER_RATE_LIMIT_COUNT=10
USER_RATE_LIMIT_MS=60000

# Daily token limit per user (100k ≈ 65 average diagram requests)
DAILY_TOKEN_LIMIT=100000

# Visual feedback loop (Phase 9)
# Critique uses Groq vision — same GROQ_API_KEY, no new key needed
CRITIQUE_RATE_LIMIT_COUNT=5
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
